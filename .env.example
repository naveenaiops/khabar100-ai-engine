# ==============================================================================
# Khabar100 Public Portfolio Environment Configuration Template
# ==============================================================================
# Instructions:
# 1. Copy this file to '.env.local' in the root directory for local development.
# 2. Replace the placeholder values below with your specific service keys.
# 3. DO NOT commit '.env.local' or any actual credentials to your public repository.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Supabase Public Config (Accessible Client-Side)
# ------------------------------------------------------------------------------
# Your Supabase Project API URL (found in Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase public anonymous API key (found in Project Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ------------------------------------------------------------------------------
# 2. Supabase Private Gating Keys (Server-Side Only - Secure)
# ------------------------------------------------------------------------------
# CRITICAL: This is the service_role key that bypasses Row Level Security (RLS).
# Keep this secure. Never expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Direct database connection string (used for migration scripts, CLI db pushes, and backups)
# Session pooler (Port 5432) or transaction pooler (Port 6543)
DATABASE_URL=postgresql://postgres.your-project-id:your-db-password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true

# ------------------------------------------------------------------------------
# 3. Razorpay Payment SaaS Integration Keys (₹49/month practice subscription)
# ------------------------------------------------------------------------------
# Public-facing key ID used to initialize Razorpay checkout popup on client-side
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your_key_id_here

# Server-side order creation key ID
RAZORPAY_KEY_ID=rzp_test_your_key_id_here

# Private key secret used to sign order creations and verify checkout responses
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Secret signature used to verify webhook events from Razorpay dashboard (e.g. order.paid)
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# ------------------------------------------------------------------------------
# 4. Large Language Model (LLM) Integration API Keys
# ------------------------------------------------------------------------------
# OpenRouter API Key used to fetch structured completions (UPSC MCQ Generation / Quality Gate)
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here

# Fallback Gemini API Key for text-embedding-004 calculations
GEMINI_API_KEY=AIzaSy_your_gemini_api_key_here

# ------------------------------------------------------------------------------
# 5. Model Routing Customizations
# ------------------------------------------------------------------------------
# Main text generation model used for Daily MCQ generation and synthesis loops
OPENROUTER_GENERATION_MODEL=google/gemini-2.5-flash

# Lightweight, cost-effective validation model used for Quality Gate checks and pattern analysis
OPENROUTER_VALIDATION_MODEL=google/gemini-2.5-flash-lite

# ------------------------------------------------------------------------------
# 6. Automated Scheduler Gating
# ------------------------------------------------------------------------------
# Secure token generated by Vercel inside your deployment setting panel.
# Used to authenticate GET requests to /api/cron/generate endpoint.
CRON_SECRET=your_custom_secure_cron_token_for_validation_here

# ------------------------------------------------------------------------------
# 7. Search API Keys (For Deep RAG Context Augmentation)
# ------------------------------------------------------------------------------
# Serper.dev API Key for Google Search queries (high priority search client)
SERPER_API_KEY=your_serper_api_key_here

# Tavily.com AI Search API Key (fallback search client)
TAVILY_API_KEY=tvly-your_tavily_api_key_here
